    {
      "name": "Create a duplicate repository for the authenticated user",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "//Set the repository name as a global variable to access later. \r",
              "pm.globals.set(\"repoName\",\"JMeterRepo\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "//Validate the status code of the duplicate repository request. \r",
              "pm.test(\"Validate the status code of the duplicate repository request\", function () {\r",
              "    pm.expect(pm.response.code).to.eql(422)\r",
              "});\r",
              "\r",
              "//Validate the status message of the duplicate repository request. \r",
              "pm.test(\"Validate the status message of the duplicate repository request\", function () {\r",
              "    pm.expect(pm.response.status).to.include(\"Unprocessable Entity\")\r",
              "});\r",
              "\r",
              "//Validate the response time of the duplicate repository request. \r",
              "pm.test(\"Validate the response time of the duplicate repository request\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "//Validate the response body of the duplicate repository request\r",
              "pm.test(\"Validate the response body of the duplicate repository request\", function () {\r",
              "    pm.expect(pm.response.json().message).to.eql(\"Repository creation failed.\");\r",
              "    pm.expect(pm.response.json().errors[0].message).to.eql(\"name already exists on this account\");\r",
              "    pm.expect(pm.response.json().status).to.eql(\"422\");\r",
              "});\r",
              "\r",
              "//Validate the schema of the duplicate repository request. \r",
              "pm.test(\"Validate the schema of the duplicate repository response\", function () {\r",
              "       pm.expect(typeof (pm.response.json().message)).to.eql(\"string\");\r",
              "});\r",
              "\r",
              "//wait for 2 sec \r",
              "setTimeout(()=>{\r",
              "    console.log(\"waiting for 2 seconds\")\r",
              "},2000);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "{{bearer_token}}",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/vnd.github+json",
            "type": "text"
          },
          {
            "key": "X-GitHub-Api-Version",
            "value": "2026-03-10",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\": \"{{repoName}}\",\r\n    \"private\": true,\r\n    \"description\": \"Sample Duplicate Repo From Postman\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/user/repos",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "user",
            "repos"
          ]
        }
      },
      "response": []
