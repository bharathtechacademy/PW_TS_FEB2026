              "});\r",
              "\r",
              "//Validate the status message of the valid repository request. \r",
              "pm.test(\"Validate the status message of the valid repository request\", function () {\r",
              "    pm.expect(pm.response.status).to.include(\"Created\")\r",
              "});\r",
              "\r",
              "//Validate the response time of the valid repository request. \r",
              "pm.test(\"Validate the response time of the valid repository request\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "//Validate the response body of the valid repository request\r",
              "pm.test(\"Validate the response body of the valid repository request\", function () {\r",
              "    pm.expect(pm.response.json().name).to.eql(pm.globals.get(\"repoName\"));\r",
              "    pm.expect(pm.response.json().private).to.eql(true);\r",
              "});\r",
              "\r",
              "//Validate the schema of the valid repository request. \r",
              "pm.test(\"Validate the schema of the valid repository response\", function () {\r",
